@page "/"
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>@L["Dashboard"] - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">@L["Dashboard"]</MudText>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard Elevation="3" Class="bg-primary text-white h-100">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@L["Homeserver"]</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.h5">@MatrixSession.AuthenticatedHomeserver?.ServerName</MudText>
                <MudText Typo="Typo.body2">@MatrixSession.AuthenticatedHomeserver?.BaseUrl</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@if (isSynapse)
{
    <MudCard Elevation="3" Class="mt-6">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@L["SynapseAdminInfo"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body1" Class="mb-4">@L["ConnectedToSynapseWithAdmin"]</MudText>
        </MudCardContent>
    </MudCard>
}
