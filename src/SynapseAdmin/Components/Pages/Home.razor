@page "/"
@using Microsoft.AspNetCore.Authorization
@using SynapseAdmin.Extensions
@attribute [Authorize]

<PageTitle>@L["Dashboard"] - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">@L["Dashboard"]</MudText>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard Elevation="3" Class="bg-primary text-white h-100">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@L["Homeserver"]</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.h5">@MatrixSession.AuthenticatedHomeserver?.ServerName</MudText>
                <MudText Typo="Typo.body2">@MatrixSession.AuthenticatedHomeserver?.BaseUrl</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@if (loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-6" />
}
else if (isSynapse)
{
    <MudGrid Class="mt-6">
        @* Totals Cards *@
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h4" Class="mt-2">@totalUsers</MudText>
                <MudText Typo="Typo.subtitle1">@L["Users"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center">
                <MudIcon Icon="@Icons.Material.Filled.MeetingRoom" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h4" Class="mt-2">@totalRooms</MudText>
                <MudText Typo="Typo.subtitle1">@L["Rooms"]</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center">
                <MudIcon Icon="@Icons.Material.Filled.Report" Size="Size.Large" Color="Color.Error" />
                <MudText Typo="Typo.h4" Class="mt-2">@totalReports</MudText>
                <MudText Typo="Typo.subtitle1">@L["EventReports"]</MudText>
            </MudPaper>
        </MudItem>

        @* Tables *@
        <MudItem xs="12" lg="6">
            <MudTable Items="latestUsers" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="3" Dense="true">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">@L["LatestUsers"]</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/users">@L["Details"]</MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>@L["UserId"]</MudTh>
                    <MudTh>@L["Created"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@L["UserId"]">@context.UserId</MudTd>
                    <MudTd DataLabel="@L["Created"]">@DateTimeOffset.FromUnixTimeSeconds(context.CreationTs).ToString("g")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>

        <MudItem xs="12" lg="6">
            <MudTable Items="latestReports" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="3" Dense="true">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">@L["LatestEventReports"]</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/reports">@L["Details"]</MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>@L["Reporter"]</MudTh>
                    <MudTh>@L["Reason"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@L["Reporter"]">@context.UserId</MudTd>
                    <MudTd DataLabel="@L["Reason"]">@(string.IsNullOrWhiteSpace(context.Reason) ? "-" : context.Reason)</MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>

        @if (largestRooms.Any())
        {
            <MudItem xs="12">
                <MudTable Items="largestRooms" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="3" Dense="true">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">@L["LargestRooms"]</MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/rooms">@L["Details"]</MudButton>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>@L["Name"]</MudTh>
                        <MudTh>@L["RoomId"]</MudTh>
                        <MudTh>@L["EstimatedSize"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@L["Name"]">@context.Name</MudTd>
                        <MudTd DataLabel="@L["RoomId"]">@context.RoomId</MudTd>
                        <MudTd DataLabel="@L["EstimatedSize"]">@context.EstimatedSize.FormatSize()</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        }

        @if (topMediaUsers.Any())
        {
            <MudItem xs="12">
                <MudTable Items="topMediaUsers" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="3" Dense="true">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">@L["TopMediaUsers"]</MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/users">@L["Details"]</MudButton>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>@L["User"]</MudTh>
                        <MudTh>@L["MediaCount"]</MudTh>
                        <MudTh>@L["TotalSize"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@L["User"]">
                            <MudText Typo="Typo.body2">@context.DisplayName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.UserId</MudText>
                        </MudTd>
                        <MudTd DataLabel="@L["MediaCount"]">@context.MediaCount</MudTd>
                        <MudTd DataLabel="@L["TotalSize"]">@context.TotalSize.FormatSize()</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        }
    </MudGrid>
}
