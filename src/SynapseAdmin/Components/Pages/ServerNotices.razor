@page "/notices"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>Server Notices - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">Send Server Notice</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        Server notice functionality requires Synapse Admin API access.
    </MudAlert>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Broadcast Notice to User</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mb-4">
                        Send a message directly from the server to a specific local user. Synapse will automatically create a dedicated "Server Notices" room between the server and the user if one does not exist.
                    </MudText>
                    
                    <MudForm @ref="form" @bind-IsValid="@success">
                        <MudTextField @bind-Value="targetUserId" 
                                      Label="Target User ID" 
                                      Required="true" 
                                      RequiredError="User ID is required!"
                                      HelperText='@("Format: @user:example.com")'
                                      Variant="Variant.Outlined" 
                                      Class="mb-4" />
                                      
                        <MudTextField @bind-Value="noticeMessage" 
                                      Label="Notice Message" 
                                      Lines="5" 
                                      Required="true" 
                                      RequiredError="A message is required!"
                                      Variant="Variant.Outlined" />
                    </MudForm>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               Disabled="@(!success || isSending)" 
                               OnClick="SendNotice"
                               Class="ml-auto">
                        @if (isSending)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                            <MudText Class="ms-2">Sending...</MudText>
                        }
                        else
                        {
                            <MudText>Send Notice</MudText>
                        }
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
}