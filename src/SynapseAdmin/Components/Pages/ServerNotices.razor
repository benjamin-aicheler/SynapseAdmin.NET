@page "/notices"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>@L["ServerNotices"] - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">@L["SendServerNotice"]</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        @L["ServerNoticeApiRequired"]
    </MudAlert>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@L["BroadcastNoticeToUser"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mb-4">
                        @L["ServerNoticeDescription"]
                    </MudText>

                    <MudForm @ref="form" @bind-IsValid="@success">
                        <MudTextField @bind-Value="targetUserId" 
                                      Label="@L["TargetUserId"]" 
                                      Required="true" 
                                      RequiredError="@L["UserIdRequired"]"
                                      HelperText="@L["UserIdFormatHelper"]"
                                      Variant="Variant.Outlined" 
                                      Class="mb-4" />

                        <MudTextField @bind-Value="noticeMessage" 
                                      Label="@L["NoticeMessage"]" 
                                      Lines="5" 
                                      Required="true" 
                                      RequiredError="@L["MessageRequired"]"
                                      Variant="Variant.Outlined" />
                    </MudForm>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               Disabled="@(!success || isSending)" 
                               OnClick="SendNotice"
                               Class="ml-auto">
                        @if (isSending)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                            <MudText Class="ms-2">@L["Sending"]</MudText>
                        }
                        else
                        {
                            <MudText>@L["SendNotice"]</MudText>
                        }
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
}