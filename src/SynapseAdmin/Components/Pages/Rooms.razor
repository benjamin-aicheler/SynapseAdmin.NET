@page "/rooms"
@using SynapseAdmin.Services
@using LibMatrix.Homeservers
@using LibMatrix.Homeservers.ImplementationDetails.Synapse.Models.Responses
@inject MatrixSessionService MatrixSession
@inject NavigationManager Navigation

<PageTitle>Rooms - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">Room Management</MudText>

@if (!MatrixSession.IsLoggedIn)
{
    <MudAlert Severity="Severity.Warning" Elevation="2" Class="mb-4">
        You are not logged in. Please go to the <MudLink Href="login">Login page</MudLink>.
    </MudAlert>
}
else if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        Room management requires Synapse Admin API access.
    </MudAlert>
}
else
{
    <MudToolBar Class="mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadRooms" Disabled="@isLoading" StartIcon="@Icons.Material.Filled.Refresh">
            Refresh
        </MudButton>
        <MudSpacer />
        <MudText Typo="Typo.body2" Color="Color.Surface">Showing @rooms.Count rooms</MudText>
    </MudToolBar>

    <MudTable Items="@rooms" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@isLoading" LoadingProgressColor="Color.Info" Elevation="3">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Room ID</MudTh>
            <MudTh>Creator</MudTh>
            <MudTh>Members</MudTh>
            <MudTh>Public</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@(string.IsNullOrEmpty(context.Name) ? "No Name" : context.Name)</MudTd>
            <MudTd DataLabel="Room ID"><MudText Typo="Typo.caption">@context.RoomId</MudText></MudTd>
            <MudTd DataLabel="Creator">@context.Creator</MudTd>
            <MudTd DataLabel="Members">@context.JoinedMembers</MudTd>
            <MudTd DataLabel="Public">
                @if (context.Public)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Public</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">Private</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info">Details</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No rooms found or you haven't refreshed yet.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    private List<SynapseAdminRoomListResult.SynapseAdminRoomListResultRoom> rooms = new();
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        if (MatrixSession.IsLoggedIn && MatrixSession.AuthenticatedHomeserver is AuthenticatedHomeserverSynapse)
        {
            await LoadRooms();
        }
    }

    private async Task LoadRooms()
    {
        if (MatrixSession.AuthenticatedHomeserver is AuthenticatedHomeserverSynapse synapseAdmin)
        {
            isLoading = true;
            rooms.Clear();
            try
            {
                await foreach (var room in synapseAdmin.Admin.SearchRoomsAsync(limit: 100))
                {
                    rooms.Add(room);
                    StateHasChanged(); // Update UI as rooms stream in
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading rooms: {ex.Message}");
            }
            finally
            {
                isLoading = false;
            }
        }
    }
}
