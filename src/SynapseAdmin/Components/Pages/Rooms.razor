@page "/rooms"
@using SynapseAdmin.Services
@using LibMatrix.Homeservers
@using LibMatrix.Homeservers.ImplementationDetails.Synapse.Models.Responses
@inject MatrixSessionService MatrixSession
@inject NavigationManager Navigation

<PageTitle>Rooms - SynapseAdmin.NET</PageTitle>

<h1>Room Management</h1>

@if (!MatrixSession.IsLoggedIn)
{
    <div class="alert alert-warning">
        You are not logged in. Please go to the <a href="login">Login page</a>.
    </div>
}
else if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <div class="alert alert-danger">
        Room management requires Synapse Admin API access.
    </div>
}
else
{
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <div>
            <button class="btn btn-primary" @onclick="LoadRooms" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                Refresh
            </button>
        </div>
        <div class="text-muted">
            Showing @rooms.Count rooms
        </div>
    </div>

    @if (rooms.Count == 0 && !isLoading)
    {
        <div class="alert alert-info">No rooms found or you haven't refreshed yet.</div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Room ID</th>
                    <th>Creator</th>
                    <th>Members</th>
                    <th>Public</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var room in rooms)
                {
                    <tr>
                        <td>@(string.IsNullOrEmpty(room.Name) ? "No Name" : room.Name)</td>
                        <td><small>@room.RoomId</small></td>
                        <td>@room.Creator</td>
                        <td>@room.JoinedMembers</td>
                        <td>
                            @if (room.Public)
                            {
                                <span class="badge bg-success">Public</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Private</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-info">Details</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<SynapseAdminRoomListResult.SynapseAdminRoomListResultRoom> rooms = new();
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        if (MatrixSession.IsLoggedIn && MatrixSession.AuthenticatedHomeserver is AuthenticatedHomeserverSynapse)
        {
            await LoadRooms();
        }
    }

    private async Task LoadRooms()
    {
        if (MatrixSession.AuthenticatedHomeserver is AuthenticatedHomeserverSynapse synapseAdmin)
        {
            isLoading = true;
            rooms.Clear();
            try
            {
                await foreach (var room in synapseAdmin.Admin.SearchRoomsAsync(limit: 100))
                {
                    rooms.Add(room);
                    StateHasChanged(); // Update UI as rooms stream in
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading rooms: {ex.Message}");
            }
            finally
            {
                isLoading = false;
            }
        }
    }
}
