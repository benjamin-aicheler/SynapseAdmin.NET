@page "/rooms/{RoomId}"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>@L["RoomDetails"] - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">@L["RoomDetails"]</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        @L["SynapseAdminApiRequired"]
    </MudAlert>
}
else if (roomDetails == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@L["Overview"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string"><b>@L["ID"]:</b> <MudText Typo="Typo.caption" Style="word-break: break-all;">@roomDetails.RoomId</MudText></MudListItem>
                        <MudListItem T="string"><b>@L["Name"]:</b> @(string.IsNullOrEmpty(roomDetails.Name) ? L["NoName"] : roomDetails.Name)</MudListItem>
                        <MudListItem T="string"><b>@L["Alias"]:</b> @roomDetails.CanonicalAlias</MudListItem>
                        <MudListItem T="string"><b>@L["Creator"]:</b> @roomDetails.Creator</MudListItem>
                        <MudListItem T="string"><b>@L["Version"]:</b> @roomDetails.Version</MudListItem>
                        <MudListItem T="string"><b>@L["Members"]:</b> @roomDetails.JoinedMembers (@L["Local"]: @roomDetails.JoinedLocalMembers)</MudListItem>
                        <MudListItem T="string"><b>@L["Public"]:</b> @roomDetails.Public</MudListItem>
                        <MudListItem T="string"><b>@L["JoinRules"]:</b> @roomDetails.JoinRules</MudListItem>
                        <MudListItem T="string"><b>@L["GuestAccess"]:</b> @roomDetails.GuestAccess</MudListItem>
                        <MudListItem T="string"><b>@L["HistoryVisibility"]:</b> @roomDetails.HistoryVisibility</MudListItem>
                        <MudListItem T="string"><b>@L["Encryption"]:</b> @roomDetails.Encryption</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@L["Actions"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteRoom" Class="mb-2 mr-2">@L["DeleteRoom"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteAndBlockRoom" Class="mb-2 mr-2">@L["DeleteAndBlockRoom"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="BlockRoom" Class="mb-2 mr-2">@L["BlockRoom"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="QuarantineMedia" Class="mb-2">@L["QuarantineMedia"]</MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudTabs Class="mt-6" Elevation="3" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="@L["Members"]" Icon="@Icons.Material.Filled.People">
            @if (members == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="m-4" />
            }
            else
            {
                <MudTable Items="members.Members" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                    <HeaderContent>
                        <MudTh>@L["UserId"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@L["UserId"]">@context</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="@L["StateEvents"]" Icon="@Icons.Material.Filled.List">
            @if (stateEvents == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="m-4" />
            }
            else
            {
                <MudTable Items="stateEvents.Events" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                    <HeaderContent>
                        <MudTh>@L["Type"]</MudTh>
                        <MudTh>@L["StateKey"]</MudTh>
                        <MudTh>@L["Sender"]</MudTh>
                        <MudTh>@L["Content"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@L["Type"]">@context.Type</MudTd>
                        <MudTd DataLabel="@L["StateKey"]">@context.StateKey</MudTd>
                        <MudTd DataLabel="@L["Sender"]">@context.Sender</MudTd>
                        <MudTd DataLabel="@L["Content"]"><pre style="max-height: 200px; max-width: 500px; overflow: auto; font-size: 0.8em; white-space: pre-wrap;">@context.RawContent?.ToJsonString()</pre></MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }
        </MudTabPanel>
    </MudTabs>
}