@page "/rooms/{RoomId}"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>@L["RoomDetails"] - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">@L["RoomDetails"]</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        @L["SynapseAdminApiRequired"]
    </MudAlert>
}
else if (room == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    @if (room.IsTombstoned)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-4">
            @L["RoomUpgradedAlert"]
            @if (!string.IsNullOrEmpty(room.ReplacementRoom))
            {
                <MudButton Href="@($"/rooms/{Uri.EscapeDataString(room.ReplacementRoom)}")"
                           Variant="Variant.Text"
                           Color="Color.Inherit"
                           Class="ml-2">
                    @L["GoToReplacementRoom"]
                </MudButton>
            }
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@L["Overview"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string"><b>@L["ID"]:</b> <MudText Typo="Typo.caption" Style="word-break: break-all;">@room.RoomId</MudText></MudListItem>
                        <MudListItem T="string"><b>@L["Name"]:</b> @(string.IsNullOrEmpty(room.Name) ? L["NoName"] : room.Name)</MudListItem>
                        <MudListItem T="string"><b>@L["Alias"]:</b> @room.CanonicalAlias</MudListItem>
                        <MudListItem T="string"><b>@L["Creator"]:</b> @room.Creator</MudListItem>
                        <MudListItem T="string"><b>@L["Version"]:</b> @room.Version</MudListItem>
                        @if (room.IsTombstoned)
                        {
                            <MudListItem T="string"><b>@L["ReplacementRoom"]:</b> <MudText Typo="Typo.caption" Style="word-break: break-all;">@room.ReplacementRoom</MudText></MudListItem>
                        }
                        <MudListItem T="string"><b>@L["Members"]:</b> @room.JoinedMembers (@L["Local"]: @room.JoinedLocalMembers)</MudListItem>
                        <MudListItem T="string"><b>@L["Public"]:</b> @room.Public</MudListItem>
                        <MudListItem T="string"><b>@L["JoinRules"]:</b> @room.JoinRules</MudListItem>
                        <MudListItem T="string"><b>@L["GuestAccess"]:</b> @room.GuestAccess</MudListItem>
                        <MudListItem T="string"><b>@L["HistoryVisibility"]:</b> @room.HistoryVisibility</MudListItem>
                        <MudListItem T="string"><b>@L["Encryption"]:</b> @room.Encryption</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@L["Actions"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteRoom" Class="mb-2 mr-2">@L["DeleteRoom"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteAndBlockRoom" Class="mb-2 mr-2">@L["DeleteAndBlockRoom"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="BlockRoom" Class="mb-2 mr-2">@L["BlockRoom"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="QuarantineMedia" Class="mb-2">@L["QuarantineMedia"]</MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudTabs Class="mt-6" Elevation="3" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="@L["Members"]" Icon="@Icons.Material.Filled.People">
            <MudTable Items="room.Members" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>@L["UserId"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@L["UserId"]">@context</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="@L["StateEvents"]" Icon="@Icons.Material.Filled.List">
            <MudTable Items="room.StateEvents" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>@L["Type"]</MudTh>
                    <MudTh>@L["StateKey"]</MudTh>
                    <MudTh>@L["Sender"]</MudTh>
                    <MudTh>@L["Content"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@L["Type"]">@context.Type</MudTd>
                    <MudTd DataLabel="@L["StateKey"]">@context.StateKey</MudTd>
                    <MudTd DataLabel="@L["Sender"]">@context.Sender</MudTd>
                    <MudTd DataLabel="@L["Content"]"><pre style="max-height: 200px; max-width: 500px; overflow: auto; font-size: 0.8em; white-space: pre-wrap;">@context.RawContent</pre></MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="@L["Media"]" Icon="@Icons.Material.Filled.PermMedia">
            @if (room.Media == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="m-4" />
            }
            else
            {
                <MudText Typo="Typo.h6" Class="mt-4 mb-2">@L["LocalMedia"]</MudText>
                @if (room.Media.Local.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mb-4">@L["NoLocalMedia"]</MudText>
                }
                else
                {
                    <MudTable Items="room.Media.Local" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Class="mb-6">
                        <HeaderContent>
                            <MudTh>@L["MediaId"]</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@L["MediaId"]">@context.MediaId</MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>
                }

                <MudText Typo="Typo.h6" Class="mt-4 mb-2">@L["RemoteMedia"]</MudText>
                @if (room.Media.Remote.Count == 0)
                {
                    <MudText Typo="Typo.body2">@L["NoRemoteMedia"]</MudText>
                }
                else
                {
                    <MudTable Items="room.Media.Remote" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                        <HeaderContent>
                            <MudTh>@L["MediaId"]</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@L["MediaId"]">@context.MediaId</MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>
                }
            }
        </MudTabPanel>
    </MudTabs>
}
