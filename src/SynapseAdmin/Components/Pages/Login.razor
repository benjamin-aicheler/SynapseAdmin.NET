@page "/login"
@using SynapseAdmin.Models.ViewModels
@using SynapseAdmin.Services
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>@L["Login"] - SynapseAdmin.NET</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 100vh;">
    <MudPaper Elevation="4" Class="pa-8" Style="width: 100%; max-width: 400px;">
        <div class="d-flex flex-column align-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.h4" Align="Align.Center">@L["AppName"]</MudText>
            <MudText Typo="Typo.subtitle1" Align="Align.Center" Color="Color.Secondary">@L["LoginTitle"]</MudText>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="@errorSeverity" Variant="Variant.Filled" Class="mb-4">@errorMessage</MudAlert>
        }

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            
            <MudTextField Label="@L["HomeserverUrl"]" @bind-Value="loginModel.Homeserver" 
                          Variant="Variant.Outlined" Margin="Margin.Normal"
                          Placeholder="https://matrix.org" 
                          For="@(() => loginModel.Homeserver)" />

            <MudTextField Label="@L["Username"]" @bind-Value="loginModel.Username" 
                          Variant="Variant.Outlined" Margin="Margin.Normal"
                          Placeholder="@usernamePlaceholder"
                          For="@(() => loginModel.Username)" />

            <MudTextField Label="@L["Password"]" @bind-Value="loginModel.Password" 
                          InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Normal"
                          For="@(() => loginModel.Password)" />

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" 
                       FullWidth="true" Class="mt-6 py-3" Disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">@L["LoggingIn"]</MudText>
                }
                else
                {
                    @L["Login"]
                }
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>
