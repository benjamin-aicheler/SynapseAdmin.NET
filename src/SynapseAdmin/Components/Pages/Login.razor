@page "/login"

<PageTitle>@L["Login"] - SynapseAdmin.NET</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Color="Color.Primary">@L["LoginTitle"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
            }
            
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                
                <MudTextField @bind-Value="loginModel.Homeserver" Label="@L["HomeserverUrl"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" Required="true" Placeholder="https://matrix.org" />
                
                <MudTextField @bind-Value="loginModel.Username" Label="@L["Username"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" Required="true" Placeholder="@usernamePlaceholder" />
                
                <MudTextField @bind-Value="loginModel.Password" Label="@L["Password"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-6" InputType="InputType.Password" Required="true" />
                
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">@L["LoggingIn"]</MudText>
                    }
                    else
                    {
                        <MudText>@L["Login"]</MudText>
                    }
                </MudButton>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>
