@page "/about"

<PageTitle>@L["About"] - SynapseAdmin.NET</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudText Typo="Typo.h3" Class="mb-2">@L["AboutSynapseAdmin"]</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-6">@L["ModernAdminToolDescription"]</MudText>

    <MudCard Elevation="3" Class="mb-6">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@L["ProjectInformation"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudList T="string">
                <MudListItem Icon="@Icons.Material.Filled.Build">
                    <strong>@L["Framework"]:</strong> .NET 10 Blazor Server
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Code">
                    <strong>@L["SDK"]:</strong> <MudLink Href="https://github.com/Rory-LibMatrix/LibMatrix" Target="_blank">LibMatrix</MudLink>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Extension">
                    <strong>@L["Utilities"]:</strong> <MudLink Href="https://github.com/TheArcaneBrony/ArcaneLibs" Target="_blank">ArcaneLibs</MudLink>, Serilog
                </MudListItem>
                <MudListItem Icon="@Icons.Custom.Brands.GitHub">
                    <strong>@L["SourceCode"]:</strong> <MudLink Href="https://github.com/benjamin-aicheler/SynapseAdmin.NET" Target="_blank">GitHub Repository</MudLink>
                </MudListItem>
            </MudList>
        </MudCardContent>
    </MudCard>

    <MudCard Elevation="3" Class="border-solid border-l-4 border-l-primary">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6" Color="Color.Primary">@L["LicenseCompliance"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body2" Class="mb-4">
                @L["AgplNotice"]
            </MudText>
            
            <MudText Typo="Typo.subtitle2" Class="mb-2">@L["ProjectIncorporates"]</MudText>
            <MudList T="string" Dense="true" Class="mb-4">
                <MudListItem><strong>LibMatrix</strong>: Licensed under AGPL-3.0</MudListItem>
                <MudListItem><strong>ArcaneLibs</strong>: Licensed under AGPL-3.0</MudListItem>
                <MudListItem><strong>MudBlazor</strong>: Licensed under MIT</MudListItem>
                <MudListItem><strong>Serilog</strong>: Licensed under Apache-2.0</MudListItem>
            </MudList>

            <MudDivider Class="my-4" />
            
            <MudText Typo="Typo.subtitle1" Color="Color.Warning" Class="mb-2">@L["RemoteNetworkInteraction"]</MudText>
            <MudText Typo="Typo.caption">
                @L["RemoteNetworkNotice"]
            </MudText>
        </MudCardContent>
    </MudCard>
</MudContainer>
