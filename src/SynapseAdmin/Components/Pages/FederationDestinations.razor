@page "/federation"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>Federation Destinations - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">Federation Destinations</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        Federation management requires Synapse Admin API access.
    </MudAlert>
}
else
{
    <MudToolBar Class="mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadTable" StartIcon="@Icons.Material.Filled.Refresh">
            Refresh
        </MudButton>
        <MudSpacer />
        @if (totalDestinations.HasValue)
        {
            <MudText Typo="Typo.body2" Color="Color.Surface">Total @totalDestinations destinations</MudText>
        }
    </MudToolBar>

    <MudTable ServerData="ServerReload" @ref="table" Hover="true" Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Info" Elevation="3">
        <HeaderContent>
            <MudTh>Destination</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Last Retry</MudTh>
            <MudTh>Retry Interval</MudTh>
            <MudTh>Failure Time</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Destination"><MudText Typo="Typo.body2">@context.Destination</MudText></MudTd>
            <MudTd DataLabel="Status">
                @if (context.FailureTsDateTime.HasValue)
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Failing</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">OK</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Last Retry">
                @(context.RetryLastTs > 0 ? context.RetryLastTsDateTime?.ToString("g") : "-")
            </MudTd>
            <MudTd DataLabel="Retry Interval">
                @(context.RetryInterval > 0 ? context.RetryIntervalTimeSpan.ToString("c") : "-")
            </MudTd>
            <MudTd DataLabel="Failure Time">
                @(context.FailureTsDateTime?.ToString("g") ?? "-")
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Warning" OnClick="@(() => ResetConnection(context.Destination))" Disabled="!context.FailureTsDateTime.HasValue">Reset Connection</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No federation destinations found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}