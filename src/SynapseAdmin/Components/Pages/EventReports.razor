@page "/reports"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>@L["EventReports"] - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">@L["EventReports"]</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        @L["EventReportApiRequired"]
    </MudAlert>
}
else
{
    <MudToolBar Class="mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadTable" StartIcon="@Icons.Material.Filled.Refresh">
            @L["Refresh"]
        </MudButton>
        <MudSpacer />
        @if (totalReports.HasValue)
        {
            <MudText Typo="Typo.body2" Color="Color.Surface">@string.Format(L["TotalReports"], totalReports)</MudText>
        }
    </MudToolBar>

    <MudTable ServerData="ServerReload" @ref="table" Hover="true" Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Info" Elevation="3">
        <HeaderContent>
            <MudTh>@L["ReportId"]</MudTh>
            <MudTh>@L["Reporter"]</MudTh>
            <MudTh>@L["Sender"]</MudTh>
            <MudTh>@L["Room"]</MudTh>
            <MudTh>@L["Reason"]</MudTh>
            <MudTh>@L["Score"]</MudTh>
            <MudTh>@L["ReportedAt"]</MudTh>
            <MudTh>@L["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["ReportId"]"><MudText Typo="Typo.caption">@context.Id</MudText></MudTd>
            <MudTd DataLabel="@L["Reporter"]">@context.UserId</MudTd>
            <MudTd DataLabel="@L["Sender"]">@context.Sender</MudTd>
            <MudTd DataLabel="@L["Room"]">@(string.IsNullOrEmpty(context.CanonicalAlias) ? context.RoomId : context.CanonicalAlias)</MudTd>
            <MudTd DataLabel="@L["Reason"]">@(string.IsNullOrEmpty(context.Reason) ? "-" : context.Reason)</MudTd>
            <MudTd DataLabel="@L["Score"]">@context.Score</MudTd>
            <MudTd DataLabel="@L["ReportedAt"]">@context.ReceivedTsDateTime.ToString("g")</MudTd>
            <MudTd DataLabel="@L["Actions"]">
                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteReport(context.Id))">@L["Dismiss"]</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>@L["NoReportsFound"]</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}
