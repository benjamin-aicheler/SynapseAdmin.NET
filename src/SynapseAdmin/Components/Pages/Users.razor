@page "/users"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>@L["Users"] - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">@L["UserManagement"]</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        @L["SynapseAdminApiRequired"]
    </MudAlert>
}
else
{
    <MudToolBar Class="mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadTable" StartIcon="@Icons.Material.Filled.Refresh">
            @L["Refresh"]
        </MudButton>
        <MudSpacer />
        @if (totalUsers.HasValue)
        {
            <MudText Typo="Typo.body2" Color="Color.Surface">@string.Format(L["TotalUsersOnServer"], totalUsers)</MudText>
        }
    </MudToolBar>

    <MudTable ServerData="ServerReload" @ref="table" Hover="true" Breakpoint="Breakpoint.Sm" LoadingProgressColor="Color.Info" Elevation="3">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortLabel="name" T="UserListViewModel">@L["UserId"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="displayname" T="UserListViewModel">@L["DisplayName"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="admin" T="UserListViewModel">@L["Admin"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="is_guest" T="UserListViewModel">@L["Guest"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="deactivated" T="UserListViewModel">@L["Deactivated"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="creation_ts" T="UserListViewModel">@L["Created"]</MudTableSortLabel></MudTh>
            <MudTh>@L["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["UserId"]"><MudText Typo="Typo.body2">@context.UserId</MudText></MudTd>
            <MudTd DataLabel="@L["DisplayName"]">@(string.IsNullOrEmpty(context.DisplayName) ? "-" : context.DisplayName)</MudTd>
            <MudTd DataLabel="@L["Admin"]">
                @if (context.Admin)
                {
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">@L["Admin"]</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">@L["User"]</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L["Guest"]">
                @if (context.IsGuest)
                {
                    <MudChip T="string" Color="Color.Secondary" Size="Size.Small">@L["Guest"]</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L["Deactivated"]">
                @if (context.Deactivated)
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">@L["Deactivated"]</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L["Created"]">@context.CreationTsDateTime.ToString("g")</MudTd>
            <MudTd DataLabel="@L["Actions"]">
                <MudButton Href="@($"/users/{Uri.EscapeDataString(context.UserId)}")" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info">@L["Details"]</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>@L["NoUsersFound"]</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}
