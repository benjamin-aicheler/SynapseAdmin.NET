@page "/users/{UserId}"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>@L["UserDetails"] - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">@L["UserDetails"]</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        @L["SynapseAdminApiRequired"]
    </MudAlert>
}
else if (user == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@L["Overview"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div class="d-flex align-center mb-4">
                        @if (!string.IsNullOrEmpty(user.AvatarUrl))
                        {
                            <MudAvatar Size="Size.Large" Class="mr-4">
                                <MudImage Src="@(user.AvatarUrl.StartsWith("mxc://") ? $"{MatrixSession.AuthenticatedHomeserver.WellKnownUris.Client}/_matrix/media/v3/download/{user.AvatarUrl.Substring(6)}" : user.AvatarUrl)" />
                            </MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">@(user.DisplayName?.FirstOrDefault() ?? user.UserId.FirstOrDefault())</MudAvatar>
                        }
                        <div>
                            <MudText Typo="Typo.h6">@(string.IsNullOrEmpty(user.DisplayName) ? user.UserId : user.DisplayName)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@user.UserId</MudText>
                        </div>
                    </div>

                    <MudList T="string" Dense="true">
                        <MudListItem T="string"><b>@L["ID"]:</b> <MudText Typo="Typo.caption" Style="word-break: break-all;">@user.UserId</MudText></MudListItem>
                        <MudListItem T="string"><b>@L["Created"]:</b> @user.CreationTsDateTime.ToString("f")</MudListItem>
                        <MudListItem T="string"><b>@L["Status"]:</b> 
                            @if (user.Deactivated)
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small">@L["Deactivated"]</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">@L["Active"]</MudChip>
                            }
                        </MudListItem>
                        <MudListItem T="string"><b>@L["Role"]:</b> 
                            @if (user.Admin)
                            {
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small">@L["Admin"]</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">@L["StandardUser"]</MudChip>
                            }
                        </MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@L["Actions"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeactivateUser" Class="mb-2 mr-2" Disabled="@user.Deactivated">@L["DeactivateUser"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="LoginAsUser" Class="mb-2 mr-2">@L["LoginAsUserShadow"]</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="QuarantineAllMedia" Class="mb-2">@L["QuarantineMedia"]</MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudTabs Class="mt-6" Elevation="3" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="@L["Media"]" Icon="@Icons.Material.Filled.PermMedia">
             @if (user.Media == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="m-4" />
            }
            else
            {
                <MudTable Items="user.Media.Media" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                    <HeaderContent>
                        <MudTh>@L["MediaId"]</MudTh>
                        <MudTh>@L["Type"]</MudTh>
                        <MudTh>@L["Size"]</MudTh>
                        <MudTh>@L["Created"]</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="@L["MediaId"]">@context.MediaId</MudTd>
                        <MudTd DataLabel="@L["Type"]">@context.UploadName</MudTd>
                        <MudTd DataLabel="@L["Size"]">@(context.MediaLength / 1024) KB</MudTd>
                        <MudTd DataLabel="@L["Created"]">@DateTimeOffset.FromUnixTimeMilliseconds(context.CreatedTimestamp).DateTime.ToString("g")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }
        </MudTabPanel>
    </MudTabs>
}
