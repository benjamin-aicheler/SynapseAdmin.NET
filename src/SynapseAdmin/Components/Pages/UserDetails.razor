@page "/users/{UserId}"
@using LibMatrix.Homeservers
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>User Details - SynapseAdmin.NET</PageTitle>

<MudText Typo="Typo.h3" Class="mb-6">User Details</MudText>

@if (MatrixSession.AuthenticatedHomeserver is not AuthenticatedHomeserverSynapse synapseAdmin)
{
    <MudAlert Severity="Severity.Error" Elevation="2" Class="mb-4">
        User management requires Synapse Admin API access.
    </MudAlert>
}
else if (userDetails == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Overview</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div class="d-flex align-center mb-4">
                        @if (!string.IsNullOrEmpty(userDetails.AvatarUrl))
                        {
                            <MudAvatar Size="Size.Large" Class="mr-4">
                                <MudImage Src="@(userDetails.AvatarUrl.StartsWith("mxc://") ? $"{MatrixSession.AuthenticatedHomeserver.WellKnownUris.Client}/_matrix/media/v3/download/{userDetails.AvatarUrl.Substring(6)}" : userDetails.AvatarUrl)" />
                            </MudAvatar>
                        }
                        else
                        {
                            <MudAvatar Color="Color.Primary" Size="Size.Large" Class="mr-4">@(userDetails.DisplayName?.FirstOrDefault() ?? userDetails.Name.FirstOrDefault())</MudAvatar>
                        }
                        <div>
                            <MudText Typo="Typo.h6">@(string.IsNullOrEmpty(userDetails.DisplayName) ? userDetails.Name : userDetails.DisplayName)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@userDetails.Name</MudText>
                        </div>
                    </div>

                    <MudList T="string" Dense="true">
                        <MudListItem T="string"><b>ID:</b> <MudText Typo="Typo.caption" Style="word-break: break-all;">@userDetails.Name</MudText></MudListItem>
                        <MudListItem T="string"><b>Created:</b> @userDetails.CreationTsDateTime.ToString("f")</MudListItem>
                        <MudListItem T="string"><b>Status:</b> 
                            @if (userDetails.Deactivated)
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small">Deactivated</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Active</MudChip>
                            }
                        </MudListItem>
                        <MudListItem T="string"><b>Role:</b> 
                            @if (userDetails.Admin == true)
                            {
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small">Admin</MudChip>
                            }
                            else if (userDetails.IsGuest == true)
                            {
                                <MudChip T="string" Color="Color.Secondary" Size="Size.Small">Guest</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">Standard User</MudChip>
                            }
                        </MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Actions</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeactivateUser" Class="mb-2 mr-2" Disabled="@userDetails.Deactivated">Deactivate User</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="LoginAsUser" Class="mb-2 mr-2">Login as User (Shadow)</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="QuarantineAllMedia" Class="mb-2">Quarantine Media</MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
    
    <MudTabs Class="mt-6" Elevation="3" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="Media" Icon="@Icons.Material.Filled.PermMedia">
             @if (media == null)
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="m-4" />
            }
            else
            {
                <MudTable Items="media.Media" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                    <HeaderContent>
                        <MudTh>Media ID</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Size</MudTh>
                        <MudTh>Created</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Media ID">@context.MediaId</MudTd>
                        <MudTd DataLabel="Type">@context.UploadName</MudTd>
                        <MudTd DataLabel="Size">@(context.MediaLength / 1024) KB</MudTd>
                        <MudTd DataLabel="Created">@DateTimeOffset.FromUnixTimeMilliseconds(context.CreatedTimestamp).DateTime.ToString("g")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }
        </MudTabPanel>
    </MudTabs>
}