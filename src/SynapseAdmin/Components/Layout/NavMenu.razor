<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Dashboard</MudNavLink>
    <MudNavLink Href="rooms" Icon="@Icons.Material.Filled.ChatBubbleOutline">Rooms</MudNavLink>
    <MudNavLink Href="users" Icon="@Icons.Material.Filled.People">Users</MudNavLink>
    <MudNavLink Href="reports" Icon="@Icons.Material.Filled.Report">Event Reports</MudNavLink>
    <MudNavLink Href="federation" Icon="@Icons.Material.Filled.CloudSync">Federation</MudNavLink>
    <MudNavLink Href="notices" Icon="@Icons.Material.Filled.Announcement">Server Notices</MudNavLink>
    <MudNavLink Href="tokens" Icon="@Icons.Material.Filled.Key">Registration Tokens</MudNavLink>
    
    <AuthorizeView>
        <Authorized>
            <MudNavLink OnClick="Logout" Icon="@Icons.Material.Filled.Logout">Logout</MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="login" Icon="@Icons.Material.Filled.Person">Login</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
    
    <MudNavGroup Title="Utilities" Expanded="false" Icon="@Icons.Material.Filled.Build">
        <MudNavLink Href="counter" Icon="@Icons.Material.Filled.AddBox">Counter</MudNavLink>
        <MudNavLink Href="weather" Icon="@Icons.Material.Filled.Cloud">Weather</MudNavLink>
    </MudNavGroup>

    <MudNavLink Href="about" Icon="@Icons.Material.Filled.Info">About</MudNavLink>
</MudNavMenu>

@code {
    [Inject] private SynapseAdmin.Services.MatrixAuthenticationStateProvider AuthProvider { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private async Task Logout()
    {
        await AuthProvider.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
